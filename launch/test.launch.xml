<?xml version="1.0"?>
<launch>
  <arg name="robot_description" default="$(command 'xacro $(find-pkg-share ur10e_support)/urdf/workcell.xacro')"/>
  <arg name="rviz" default="true"/>
  <arg name="rviz_config" default="$(find-pkg-share ur10e_support)/config/rviz_base_config.rviz" if="$(var rviz)"/>

  <node pkg="joint_state_publisher" exec="joint_state_publisher">
    <param name="source_list" value="[joint_states, joint_state_broadcaster/joint_states]"/>
  </node>

  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
    <param name="robot_description" value="$(var robot_description)"/>
  </node>

  <group if="$(var rviz)">
    <node pkg="rviz2" exec="rviz2" args="-d $(var rviz_config)">
      <param name="robot_description" value="$(var robot_description)"/>
    </node>
  </group>

</launch>
